{
  "manifest_version": 3,
  "name": "CleanNews Vault",
  "version": "3.0.0",
  "description": "Extrae y guarda artículos limpios con un botón flotante. Biblioteca personal con colecciones, búsqueda, modo oscuro y exportación.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CleanNews Vault"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+E",
        "mac": "Alt+E"
      },
      "description": "Abrir CleanNews Vault"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "Alt+B"
      },
      "description": "Abrir/cerrar panel lateral"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/db.js",
        "utils/url.js",
        "utils/search.js",
        "utils/auto-tagger.js",
        "utils/storage.js",
        "utils/export.js",
        "content/readability.js",
        "content/content.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/sidebar.css",
        "library/*",
        "reader/*",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
