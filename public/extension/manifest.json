{
  "manifest_version": 3,
  "name": "CleanNews Vault",
  "version": "4.0.0",
  "description": "Extrae y guarda artículos limpios desde un Side Panel. Biblioteca personal con colecciones, búsqueda, modo oscuro y exportación.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "contextMenus"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CleanNews Vault"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+E",
        "mac": "Alt+E"
      },
      "description": "Abrir CleanNews Vault"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "1024": "icons/icon1024.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/readability.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
