{
  "manifest_version": 3,
  "name": "CleanNews Vault",
  "version": "2.0.0",
  "description": "Extrae y guarda artículos limpios. Biblioteca personal con colecciones, búsqueda fuzzy, modo oscuro, progreso de lectura y exportación PDF.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "sidePanel"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CleanNews Vault"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+E",
        "mac": "Alt+E"
      },
      "description": "Abrir CleanNews Vault"
    },
    "extract-article": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Extraer artículo de la pestaña actual"
    },
    "open-library": {
      "suggested_key": {
        "default": "Alt+L",
        "mac": "Alt+L"
      },
      "description": "Abrir biblioteca"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "Alt+B"
      },
      "description": "Abrir panel lateral"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "library/*",
        "reader/*",
        "sidepanel/*",
        "utils/storage.js",
        "utils/export.js",
        "utils/db.js",
        "utils/url.js",
        "utils/search.js",
        "utils/auto-tagger.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
