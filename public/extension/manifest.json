{
  "manifest_version": 3,
  "name": "CleanNews Vault",
  "version": "1.0.0",
  "description": "Extrae y guarda artículos limpios de cualquier página web. Almacena, organiza y lee tus artículos favoritos sin distracciones.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/readability.js", "content/content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "library/library.html",
        "library/library.css",
        "library/library.js",
        "reader/reader.html",
        "reader/reader.css",
        "reader/reader.js",
        "utils/storage.js",
        "utils/export.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
